# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version

# Local config — never commit user paths or keys
.env

# Build / packaging
*.egg-info/
build/
dist/

# Generated extraction outputs (very large + recreatable)
out/
*.json
!*.geojson.example
*.png
*.jpg
*.pdf
*.geojson

# but keep these specific committed examples / docs
!docs/*.png
!docs/*.geojson

# Generated viewer artefacts (rebuilt by web/build_data.py)
web/data/
web/data-bundle.js
web/assets/

# Throwaway probe scripts
/probe_*.py

# OS junk
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.iml

# Oodle DLL (Subnautica's IoStore needs it — bootstrap downloads at runtime)
oo2core_*.dll
oodle-data-shared.dll

# CUE4Parse texture decoder DLL (vendored locally, not redistributed)
Detex.dll

# Run / build / pip logs
*.log

# Scratch
test_out.txt
