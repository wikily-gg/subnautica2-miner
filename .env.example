# Subnautica 2 data miner — local paths.
# Copy this file to .env and fill in your own values.

# Folder containing Subnautica2-Windows.pak / .ucas / .utoc
SN2_PAKS_DIR=D:\subnautica\paks

# Folder containing CUE4Parse.dll (net8.0 build of CUE4Parse with its deps)
# Build CUE4Parse from https://github.com/FabianFG/CUE4Parse
SN2_CUE4PARSE_DLL_DIR=C:\path\to\CUE4Parse\bin\Release\net8.0

# Path to the Subnautica 2 .usmap mappings file
# Must match your game build — dump with UnrealMappingsDumper if needed
SN2_MAPPINGS_PATH=D:\subnautica\5.6.1-112084+++Project+SN2-Release-Hotfix-Subnautica2.usmap

# Output directory (optional — defaults to ./out)
# SN2_OUTPUT_DIR=

# CUE4Parse EGame value (default GAME_UE5_6 for current Subnautica 2 build)
# SN2_UE_GAME=GAME_UE5_6

# AES key — Subnautica 2 ships unencrypted so leave unset.
# SN2_AES_KEY=
